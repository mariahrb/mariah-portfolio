# ── Development environment ──────────────────────────────────────────────────
# Vite proxies /api → localhost:8080 automatically (see vite.config.ts)
# So you usually don't need to set VITE_API_URL in dev.
# Uncomment and override only if you're running the backend on a different port.

# VITE_API_URL=http://localhost:8080/api/v1
